# Copy this file to .env.local and update with your cloud URL

# Local backend (default)
NEXT_PUBLIC_API_URL=http://localhost:8001

# Railway backend (after deployment, uncomment and update)
# NEXT_PUBLIC_API_URL=https://your-app.up.railway.app

# Render backend (after deployment, uncomment and update)
# NEXT_PUBLIC_API_URL=https://your-app.onrender.com
